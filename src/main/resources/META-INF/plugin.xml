<idea-plugin>
    <id>de.juschmitt.compass</id>
    <name>Bearing</name>
    <vendor url="https://github.com/juschmitt/compass">de.juschmitt</vendor>
    <description><![CDATA[A IntelliJ IDEA plugin that enhances traditional coding with AI.
    No AI agent mode, no code suggestions/completions, no chat.
    Set an objective (optional), search for what you want to do, go through the AI-generated list and write the code yourself.
    Or use selection rewrite to let AI rewrite sections when you want to.
    ]]></description>

    <change-notes><![CDATA[Initial release.]]></change-notes>
    <idea-version since-build="252"/>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.WorkflowBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="de.juschmitt.compass.config.WorkflowAppSettings"/>

        <projectConfigurable
                instance="de.juschmitt.compass.config.WorkflowConfigurable"
                id="de.juschmitt.compass.settings"
                displayName="Bearing"
                parentId="tools"/>

        <toolWindow
                id="Bearing"
                anchor="right"
                factoryClass="de.juschmitt.compass.search.ui.SearchToolWindowFactory"
                icon="AllIcons.Actions.Find"/>

        <statusBarWidgetFactory
                id="de.juschmitt.compass.objective"
                implementation="de.juschmitt.compass.objective.ObjectiveStatusBarWidgetFactory"
                order="first"/>

        <notificationGroup id="Bearing" displayType="BALLOON" bundle="messages.WorkflowBundle"/>
        <postStartupActivity implementation="de.juschmitt.compass.search.SearchAnnotationStartup"/>
    </extensions>

    <actions>
        <action id="de.juschmitt.compass.SetObjective"
                class="de.juschmitt.compass.objective.SetObjectiveAction"
                text="Set Current Objective"
                description="Set the session objective for Bearing">
            <keyboard-shortcut first-keystroke="ctrl alt O" keymap="$default"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="MainMenu" anchor="last"/>
        </action>
        <action id="de.juschmitt.compass.RunSearch"
                class="de.juschmitt.compass.search.RunSearchAction"
                text="Run Bearing Search"
                description="Run a Bearing search">
            <keyboard-shortcut first-keystroke="ctrl alt F" keymap="$default"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="MainMenu" anchor="last"/>
        </action>
        <action id="de.juschmitt.compass.SelectionRewrite"
                class="de.juschmitt.compass.rewrite.SelectionRewriteAction"
                text="Selection Rewrite"
                description="Rewrite the current selection via Bearing">
            <keyboard-shortcut first-keystroke="ctrl alt R" keymap="$default"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="MainMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
